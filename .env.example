# Tense configuration. Copy to `.env` and adjust.
#
# Only TENSE_DATABASE_URL is needed to boot the server and run the test suite:
# those paths use the deterministic stub extractor, so the live OpenRouter tests
# simply skip when no key is set. The OpenRouter key is what turns on live
# extraction, recall, and embeddings — the real `remember`/`recall` path.
#   No key needed: pnpm test · pnpm eval:offline · pnpm seed:demo
#   Key required:  pnpm eval (live) · live MCP usage from a client

# Postgres connection (matches docker-compose.yml).
TENSE_DATABASE_URL=postgres://postgres:tense@localhost:5432/tense

# OpenRouter (OpenAI-compatible) — sole gateway for completions + embeddings.
# Required for live extraction/recall; leave blank to stay on the no-key paths.
OPENROUTER_API_KEY=

# Models passed through to OpenRouter (both user-selectable). A frontier model
# powers the recorded demo; Gemma 3 4B is one line away.
TENSE_EXTRACTION_MODEL=openai/gpt-4o-mini
TENSE_EMBEDDING_MODEL=openai/text-embedding-3-small
