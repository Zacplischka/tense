# Tense configuration. Copy to `.env` and adjust. Slice 01 only needs the DB URL;
# the model/key vars are consumed once the LLM provider lands (slice 02+).

# Postgres connection (matches docker-compose.yml).
TENSE_DATABASE_URL=postgres://postgres:tense@localhost:5432/tense

# OpenRouter (OpenAI-compatible) — sole gateway for completions + embeddings.
# Not required for slice 01 (the extractor is a deterministic stub).
OPENROUTER_API_KEY=

# User-selectable models (slice 02+). Frontier model for the recorded demo;
# Gemma 3 4B is one line away.
TENSE_EXTRACTION_MODEL=openai/gpt-4o-mini
TENSE_EMBEDDING_MODEL=openai/text-embedding-3-small
