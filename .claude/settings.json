{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/tsc-check.sh\"",
            "timeout": 120,
            "statusMessage": "Type-checking (tsc --noEmit)…"
          }
        ]
      }
    ]
  }
}
