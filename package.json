{
  "name": "tense",
  "version": "0.1.0",
  "type": "module",
  "description": "Temporal memory for AI agents — knows which version is true.",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "bin": {
    "tense": "dist/server.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "SECURITY.md",
    ".claude-plugin",
    "tense-plugin"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait && tsx scripts/bootstrap-db.ts",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "db:setup": "docker compose up -d --wait && tsx scripts/bootstrap-db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx eval/run.ts",
    "eval:offline": "tsx eval/run-offline.ts",
    "eval:report": "tsx eval/run-offline.ts --write",
    "bench": "tsx eval/bench.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "demo:agent": "tsx scripts/demo-agent.ts",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run typecheck && npm run lint && npm run build && npm test && npm run check:viewer",
    "check:viewer": "pnpm --dir viewer run typecheck && pnpm --dir viewer run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
